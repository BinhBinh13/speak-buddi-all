users ||--o{ speaking_session
users ||--o{ ai_quota_window
ai_quota_window ||--o{ speaking_session
users ||--o{ pronunciation_attempt
speaking_session ||--o{ pronunciation_attempt
payment_plan ||--o{ user_subscription
users ||--o{ user_subscription
users ||--o{ payment_transaction
payment_plan ||--o{ payment_transaction
users ||--|| user_voice_preference
elevenlabs_voice_model ||--o{ user_voice_preference
users ||--o{ translation_history
