@startuml
title UC08 — Student practices pronunciation — Screen Flow
skinparam activityBackgroundColor #FEFEFE
skinparam activityBorderColor #333333
start
:Open PronunciationPage;
:User attempts to practice pronunciation using microphone;
if (Access and input valid?) then (yes)
  :Call PronunciationService;
  :Persist/read PronunciationAttempt data if needed;
  :Display success state;
else (no)
  :Show validation/access error;
  :Keep user input where possible;
endif
stop
@enduml
