@startuml uc-04-statediagram
title UC04 — Student views personalized roadmap by selected level — State Diagram
skinparam state {
  BackgroundColor #FEFEFE
  BorderColor #333333
  FontName Helvetica
}

[*] --> Idle
Idle --> CheckingAccess : open roadmap screen

CheckingAccess --> LoginRequired : guest/no session
CheckingAccess --> LoadingSelectedLevel : authenticated

LoadingSelectedLevel --> LevelMissing : no selected A1-C2 level
LoadingSelectedLevel --> LoadingRoadmapContent : selected level valid

state "Loading roadmap content" as LoadingRoadmapContent {
  [*] --> QueryActiveContent
  QueryActiveContent --> FreshCrawledContent : active auto-published Langeek data
  QueryActiveContent --> CachedContentFallback : Langeek down/crawl failed
  FreshCrawledContent --> ContentResolved
  CachedContentFallback --> ContentResolved
  ContentResolved --> [*]
}

LoadingRoadmapContent --> RoadmapVisible : topics found
LoadingRoadmapContent --> EmptyFallback : no active topic for selected level
LoadingRoadmapContent --> Error : auth/service error

Error --> CheckingAccess : retry
LoginRequired --> [*]
LevelMissing --> [*]
RoadmapVisible --> [*]
EmptyFallback --> [*]

note right of FreshCrawledContent
  Topics/new words are mapped
  from Langeek to A1-C2 and
  published automatically.
  No Admin approval wait.
end note

note right of CachedContentFallback
  Current active cache remains visible
  when crawling fails or Langeek is down.
end note
@enduml
