# ─── SpeakBuddi Backend — env template ───────────────────────────────────────
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit .env vào Git (đã có trong .gitignore).

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── ElevenLabs (TTS) ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Đổi thành chuỗi ngẫu nhiên đủ dài khi deploy production.
JWT_SECRET=change-me-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (PostgreSQL) — sẽ dùng ở S1.8+ ─────────────────────────────────
# Ví dụ: postgresql+asyncpg://user:password@localhost:5432/speakbuddi
DATABASE_URL=

GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com

# ── Gmail SMTP (Email) — S1.7 ─────────────────────────────────────────────────
# Hướng dẫn lấy App Password: https://myaccount.google.com/apppasswords
# (Tắt 2FA → Bật → Tạo App Password "Mail" → dùng chuỗi 16 ký tự)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# URL frontend để build link reset (không có trailing slash)
FRONTEND_URL=http://localhost:5173
