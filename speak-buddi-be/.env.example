# ─── SpeakBuddi Backend — env template ───────────────────────────────────────
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit .env vào Git (đã có trong .gitignore).
AI_PROVIDER=
# ── Anthropic (Claude AI) — dùng cho hội thoại AI + dịch câu/đoạn ──────────
ANTHROPIC_API_KEY=

# ── Xiaomi MiMo — dùng cho dịch câu/đoạn (nhanh hơn, rẻ hơn Haiku) ────────
# Lấy API key tại: https://platform.xiaomimimo.com
# Nếu để trống hoặc MiMo lỗi, tự động fallback về Anthropic Haiku.
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro

# ── ElevenLabs (TTS) ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Đổi thành chuỗi ngẫu nhiên đủ dài khi deploy production.
JWT_SECRET=change-me-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (PostgreSQL) — sẽ dùng ở S1.8+ ─────────────────────────────────
# Ví dụ: postgresql+asyncpg://user:password@localhost:5432/speakbuddi
DATABASE_URL=

GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com

# ── Gmail SMTP (Email) — S1.7 (reset mật khẩu) + S8.3 (thông báo thanh toán thất bại) ──
# Hướng dẫn lấy App Password: https://myaccount.google.com/apppasswords
# (Tắt 2FA → Bật → Tạo App Password "Mail" → dùng chuỗi 16 ký tự)
# Tái dùng nguyên SMTP_* dưới đây cho send_payment_failed_email() — không cần biến mới.
# Thiếu SMTP_USER/SMTP_PASS → email payment fail/cancel sẽ skip an toàn (log warning),
# KHÔNG làm vỡ luồng webhook/cancel.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# URL frontend để build link reset (không có trailing slash)
FRONTEND_URL=http://localhost:5173

# ── Payment (S8.1) — mặc định dùng MockPaymentProvider để dev không cần config ─
# Đổi thành 'sepay' khi đã có credential Sepay thật (xem mục Sepay bên dưới).
PAYMENT_PROVIDER=mock
# Thời gian chờ thanh toán tối đa (giây) — mặc định 5 phút
PAYMENT_PENDING_TIMEOUT_SECONDS=300

# ── Sepay (S8.2) — Provider chính thức đã chốt (PO 2026-06-07) ───────────────
# CHỈ cần điền khi PAYMENT_PROVIDER=sepay; rỗng vẫn chạy MockProvider end-to-end.
# Lấy trong dashboard Sepay (https://my.sepay.vn) → mục API/Webhook:
#   - SEPAY_WEBHOOK_API_KEY: API key cấu hình ở Sepay để header
#     `Authorization: Apikey <key>` của webhook khớp khi backend xác thực.
#   - SEPAY_ACCOUNT_NUMBER / SEPAY_BANK_CODE: số tài khoản & mã ngân hàng nhận
#     tiền (dùng để sinh VietQR cho màn thanh toán nội bộ).
#   - SEPAY_PAYMENT_PREFIX: tiền tố mã thanh toán nhúng trong nội dung chuyển
#     khoản (Sepay tách `code` theo regex cấu hình dashboard — phải khớp).
# TODO: chờ PO cấp credential thật trước khi tích hợp Sepay sandbox/production
# (xem implement/S8.2-implement.md mục "Ngoài phạm vi / TODO").
SEPAY_WEBHOOK_API_KEY=
SEPAY_ACCOUNT_NUMBER=
SEPAY_BANK_CODE=
SEPAY_PAYMENT_PREFIX=SB

LANGEEK_USE_FIXTURE=false
